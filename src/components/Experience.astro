---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;

const iconMap: Record<string, string> = {
  "Python":      "python",
  "GCP":         "googlecloud",
  "FastAPI":     "fastapi",
  "Terraform":   "terraform",
  "Docker":      "docker",
  "Airflow":     "apacheairflow",
  "SQL":         "postgresql",
  "PyTorch":     "pytorch",
  "TensorFlow":  "tensorflow",
  "BigQuery":    "googlebigquery",
  "BQML":        "googlebigquery",
  "Cloud Run":     "googlecloud",
  "Cloud Functions":     "googlecloud",
  "VertexAI":     "googlecloud",
  "Looker Studio": "looker",
  "R":             "r",
};

const iconColorMap: Record<string, string> = {
  "GitHub CI/CD": "ffffff",
  "R":            "ffffff",
};

const iconMapExtra: Record<string, string> = {
  "GitHub CI/CD": "github",
};

const iconSrcMap: Record<string, string> = {
  "DBT": "/icons/dbt.png",
  "AWS": "/icons/aws.svg",
};
---

{
  hasExperience && (
    <section id="experience" class="px-5 py-10 sm:p-12 md:p-16 lg:p-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 items-start">
        <div class="lg:col-span-3">
          <h2
            class="text-2xl sm:text-3xl md:text-4xl xl:text-5xl font-bold"
            style="color: var(--text-primary)"
          >
            Experience
          </h2>
          <div
            class="w-[75px] h-[4px] mt-3 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          />
        </div>

        <div class="lg:col-span-9 space-y-5">
          {siteConfig.experience.map((exp) => (
            <div class="exp-card rounded-xl p-5 sm:p-6 md:p-8 transition-all duration-300">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-4 gap-1">
                <div>
                  <h3 class="text-base sm:text-lg font-semibold" style="color: var(--text-primary)">
                    {exp.title}
                  </h3>
                  <p class="text-sm sm:text-base font-medium" style={`color: ${siteConfig.accentColor}`}>
                    {exp.company}
                  </p>
                </div>
                <span class="text-xs font-mono shrink-0" style="color: var(--text-muted)">
                  {exp.dateRange}
                </span>
              </div>

              <ul class="space-y-2 mb-5">
                {exp.bullets.map((bullet) => (
                  <li class="flex items-start gap-3">
                    <span
                      class="inline-block w-1 h-1 rounded-full mt-2.5 flex-shrink-0"
                      style={`background-color: ${siteConfig.accentColor}`}
                    />
                    <span class="text-sm leading-relaxed" style="color: var(--text-secondary)">
                      {bullet}
                    </span>
                  </li>
                ))}
              </ul>

              {exp.techStack && exp.techStack.length > 0 && (
                <div class="flex flex-wrap gap-2 pt-4" style="border-top: 1px solid var(--border)">
                  {exp.techStack.map((tech) => {
                    const slug = iconMap[tech] ?? iconMapExtra[tech];
                    const color = iconColorMap[tech];
                    const src = iconSrcMap[tech] ?? (slug ? `https://cdn.simpleicons.org/${slug}${color ? `/${color}` : ""}` : null);
                    return (
                      <span
                        class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium rounded-md tech-badge"
                        style="color: var(--text-primary); background-color: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.18)"
                      >
                        {src && (
                          <img src={src} alt={tech} width="12" height="12" class="w-3 h-3 shrink-0" />
                        )}
                        {tech}
                      </span>
                    );
                  })}
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .exp-card {
    background-color: var(--bg-surface);
    border: 1px solid var(--border);
  }
  .exp-card:hover {
    border-color: var(--border-hover);
    background-color: var(--bg-surface-hover);
  }
  .tech-badge:hover {
    color: var(--text-secondary) !important;
    border-color: rgba(255,255,255,0.1) !important;
  }
</style>
