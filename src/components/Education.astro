---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

{
  hasEducation && (
    <section id="education" class="px-5 py-10 sm:p-12 md:p-16 lg:p-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 items-start">
        <div class="lg:col-span-3">
          <h2
            class="text-2xl sm:text-3xl md:text-4xl xl:text-5xl font-bold"
            style="color: var(--text-primary)"
          >
            Education
          </h2>
          <div
            class="w-[75px] h-[4px] mt-3 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          />
        </div>

        <div class="lg:col-span-9 space-y-5">
          {siteConfig.education.map((edu) => (
            <div class="edu-card rounded-xl p-5 sm:p-6 md:p-8 transition-all duration-300">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-4 gap-1">
                <div>
                  <h3 class="text-base sm:text-lg font-semibold" style="color: var(--text-primary)">
                    {edu.degree}
                  </h3>
                  <p class="text-sm sm:text-base font-medium" style={`color: ${siteConfig.accentColor}`}>
                    {edu.school}
                  </p>
                </div>
                <span class="text-xs font-mono shrink-0" style="color: var(--text-muted)">
                  {edu.dateRange}
                </span>
              </div>

              {edu.achievements.length > 0 && (
                <p class="text-sm leading-relaxed" style="color: var(--text-secondary)">
                  <span class="mr-2" style={`color: ${siteConfig.accentColor}`}>•</span>
                  {edu.achievements.map((achievement, i) => (
                    <>
                      {i > 0 && (
                        <span class="mx-2" style={`color: ${siteConfig.accentColor}`}>•</span>
                      )}
                      {achievement}
                    </>
                  ))}
                </p>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .edu-card {
    background-color: var(--bg-surface);
    border: 1px solid var(--border);
  }
  .edu-card:hover {
    border-color: var(--border-hover);
    background-color: var(--bg-surface-hover);
  }
</style>
