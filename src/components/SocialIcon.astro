---
interface Props {
  type: "linkedin" | "github" | "email";
  href: string;
  size?: number;
  class?: string;
}

const { type, href, size = 18, class: className = "" } = Astro.props;

const icons = {
  linkedin: `<path d="M8 11v5"/><path d="M8 8v.01"/><path d="M12 16v-5"/><path d="M16 16v-3a2 2 0 1 0 -4 0"/><path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z"/>`,
  github:   `<path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5"/>`,
  email:    `<path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"/><path d="M3 7l9 6l9 -6"/>`,
};

const ariaLabels: Record<string, string> = { linkedin: "LinkedIn", github: "GitHub", email: "Email" };
const isEmail = type === "email";
---

<a
  href={isEmail ? `mailto:${href}` : href}
  target={isEmail ? undefined : "_blank"}
  rel={isEmail ? undefined : "noopener noreferrer"}
  aria-label={ariaLabels[type]}
  class={`transition-colors duration-200 ${className}`}
>
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
    <Fragment set:html={icons[type]} />
  </svg>
</a>
