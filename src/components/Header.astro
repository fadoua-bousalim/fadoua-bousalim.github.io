---
import SocialIcon from "./SocialIcon.astro";
import { siteConfig } from "../config";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
const hasPapers = siteConfig.papers && siteConfig.papers.length > 0;
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <nav aria-label="Main navigation" class="max-w-7xl mx-auto px-6 sm:px-8 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a
      href="#hero"
      class="transition-opacity hover:opacity-70 text-[1.6rem] sm:text-[2.2rem]"
      style="font-family: 'Cormorant Garamond', serif; font-weight: 600; letter-spacing: 0.01em; color: var(--text-primary); line-height: 1;"
    >
      {siteConfig.name.split(" ")[0]}<span style={`color: ${siteConfig.accentColor}`}>.</span>
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden md:flex items-center gap-8">
      {
        hasExperience && (
          <li>
            <a href="#experience" class="text-sm font-medium transition-colors duration-200 nav-link">
              Experience
            </a>
          </li>
        )
      }
      <li>
        <a href="#about" class="text-sm font-medium transition-colors duration-200 nav-link">
          About
        </a>
      </li>
      {
        hasProjects && (
          <li>
            <a href="#projects" class="text-sm font-medium transition-colors duration-200 nav-link">
              Projects
            </a>
          </li>
        )
      }
      {
        hasEducation && (
          <li>
            <a href="#education" class="text-sm font-medium transition-colors duration-200 nav-link">
              Education
            </a>
          </li>
        )
      }
      {
        hasPapers && (
          <li>
            <a href="#papers" class="text-sm font-medium transition-colors duration-200 nav-link">
              Papers
            </a>
          </li>
        )
      }
    </ul>

    <!-- Desktop social icons -->
    <div class="hidden md:flex items-center gap-2 social-icons">
      {siteConfig.social?.linkedin && <SocialIcon type="linkedin" href={siteConfig.social.linkedin} class="social-icon" />}
      {siteConfig.social?.github && <SocialIcon type="github" href={siteConfig.social.github} class="social-icon" />}
      {siteConfig.social?.email && <SocialIcon type="email" href={siteConfig.social.email} class="social-icon" />}
    </div>

    <!-- Mobile hamburger button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg transition-colors duration-200"
      style="color: var(--text-secondary); border: 1px solid var(--border); background-color: var(--bg-surface)"
      aria-label="Toggle menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="hamburger-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <nav
    aria-label="Mobile navigation"
    id="mobile-menu"
    class="md:hidden hidden"
    style="background-color: rgba(10, 10, 18, 0.95); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-top: 1px solid var(--border)"
  >
    <div class="px-6 py-6 space-y-4">
      {
        hasExperience && (
          <a href="#experience" class="block text-base font-medium nav-link transition-colors duration-200 py-2">
            Experience
          </a>
        )
      }
      <a href="#about" class="block text-base font-medium nav-link transition-colors duration-200 py-2">
        About
      </a>
      {
        hasProjects && (
          <a href="#projects" class="block text-base font-medium nav-link transition-colors duration-200 py-2">
            Projects
          </a>
        )
      }
      {
        hasEducation && (
          <a href="#education" class="block text-base font-medium nav-link transition-colors duration-200 py-2">
            Education
          </a>
        )
      }
      {
        hasPapers && (
          <a href="#papers" class="block text-base font-medium nav-link transition-colors duration-200 py-2">
            Papers
          </a>
        )
      }

      <div class="flex items-center gap-3 pt-4" style="border-top: 1px solid var(--border); color: var(--text-secondary)">
        {siteConfig.social?.linkedin && <SocialIcon type="linkedin" href={siteConfig.social.linkedin} class="social-icon" />}
        {siteConfig.social?.github && <SocialIcon type="github" href={siteConfig.social.github} class="social-icon" />}
        {siteConfig.social?.email && <SocialIcon type="email" href={siteConfig.social.email} class="social-icon" />}
      </div>
    </div>
  </nav>
</header>

<script>
  window.addEventListener("scroll", () => {
    const header = document.getElementById("header");
    if (window.scrollY > 60) {
      header?.classList.add("scrolled");
    } else {
      header?.classList.remove("scrolled");
    }
  });

  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const hamburgerIcon = document.getElementById("hamburger-icon");
  const closeIcon = document.getElementById("close-icon");

  menuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
    hamburgerIcon?.classList.toggle("hidden");
    closeIcon?.classList.toggle("hidden");
    const isOpen = !mobileMenu?.classList.contains("hidden");
    menuBtn?.setAttribute("aria-expanded", String(isOpen));
  });

  // Close menu when a link is clicked
  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
      hamburgerIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      menuBtn?.setAttribute("aria-expanded", "false");
    });
  });
</script>

<style>
  .nav-link {
    color: var(--text-secondary);
  }
  .nav-link:hover {
    color: var(--text-primary);
  }

  .social-icons {
    color: var(--text-secondary);
  }
  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background-color: var(--bg-surface);
  }
  .social-icon:hover {
    color: var(--accent-color);
    border-color: var(--border-hover);
    background-color: var(--bg-surface-hover);
  }

  #header.scrolled {
    background-color: rgba(10, 10, 18, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
</style>
