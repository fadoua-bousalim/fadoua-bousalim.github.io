---
import { siteConfig } from "../config";
---

<section
  id="hero"
  class="relative isolate overflow-hidden min-h-screen flex flex-col justify-center"
  style={`--accent-color: ${siteConfig.accentColor}; background-color: var(--bg-base)`}
>
  <!-- Subtle grid -->
  <svg
    aria-hidden="true"
    class="absolute inset-0 -z-10 size-full [mask-image:radial-gradient(ellipse_at_top_left,white,transparent_70%)]"
    style="stroke: rgba(255,255,255,0.04)"
  >
    <defs>
      <pattern id="hero-grid" x="50%" y={-1} width={180} height={180} patternUnits="userSpaceOnUse">
        <path d="M.5 180V.5H180" fill="none"></path>
      </pattern>
    </defs>
    <rect fill="url(#hero-grid)" width="100%" height="100%" stroke-width={0}></rect>
  </svg>

  <!-- Accent glow blob top-left -->
  <div
    class="absolute -top-40 -left-40 -z-10 w-[300px] h-[300px] sm:w-[600px] sm:h-[600px] rounded-full opacity-[0.08] blur-3xl"
    style={`background-color: ${siteConfig.accentColor}`}
  ></div>
  <!-- Fainter secondary blob -->
  <div
    class="absolute top-1/2 right-0 -z-10 w-[200px] h-[200px] sm:w-[400px] sm:h-[400px] rounded-full opacity-[0.04] blur-3xl"
    style={`background-color: ${siteConfig.accentColor}`}
  ></div>

  <div class="mx-auto w-full px-5 sm:px-12 md:px-20 lg:px-32 pt-24 pb-12 sm:pt-28 sm:pb-16">
    <!-- Location badge -->
    {
      siteConfig.location && (
        <div class="mb-8 animate-fade-in">
          <span class="inline-flex items-center gap-2 text-xs font-semibold tracking-widest uppercase" style="color: var(--text-secondary)">
            <span
              class="inline-block w-2 h-2 rounded-full animate-pulse"
              style={`background-color: ${siteConfig.accentColor}`}
            />
            {siteConfig.location}
          </span>
        </div>
      )
    }

    <!-- Main headline -->
    <h1
      class="text-2xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight leading-[1.15] animate-fade-in animation-delay-100"
      style="color: var(--text-primary)"
    >
      {siteConfig.tagline}<br />
      <span style={`color: ${siteConfig.accentColor}`}>{siteConfig.taglineAccent}</span>
    </h1>

    <!-- Subtitle -->
    <p
      class="mt-5 sm:mt-6 max-w-2xl text-base sm:text-lg md:text-xl leading-relaxed sm:text-justify animate-fade-in animation-delay-200"
      style="color: var(--text-secondary)"
    >
      {siteConfig.subtitle}
    </p>

    <!-- CTA Buttons -->
    <div class="mt-10 flex flex-wrap gap-4 animate-fade-in animation-delay-300">
      <a
        href="#experience"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg text-white font-semibold text-sm sm:text-base transition-all duration-200 hover:opacity-85 hover:-translate-y-0.5"
        style={`background-color: ${siteConfig.accentColor}`}
      >
        See My Work
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
      {
        siteConfig.cvLink && (
          <a
            href={siteConfig.cvLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold text-sm sm:text-base transition-all duration-200 hover:-translate-y-0.5"
            style={`border: 1px solid ${siteConfig.accentColor}40; color: ${siteConfig.accentColor}; background: ${siteConfig.accentColor}08`}
          >
            Download CV
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
          </a>
        )
      }
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in {
    animation: fadeIn 0.7s ease-out forwards;
    opacity: 0;
  }
  .animation-delay-100 { animation-delay: 0.1s; }
  .animation-delay-200 { animation-delay: 0.25s; }
  .animation-delay-300 { animation-delay: 0.4s; }
</style>
