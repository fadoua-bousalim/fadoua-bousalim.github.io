---
import { siteConfig } from "../config";
import { getIconSrc } from "../utils/icons";

const hasProjects = siteConfig.projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="px-5 py-10 sm:p-12 md:p-16 lg:p-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-8 items-start">
        <div class="lg:col-span-3">
          <h2
            class="text-2xl sm:text-3xl md:text-4xl xl:text-5xl font-bold"
            style="color: var(--text-primary)"
          >
            Projects
          </h2>
          <div
            class="w-[75px] h-[4px] mt-3 rounded-full"
            style={`background-color: ${siteConfig.accentColor}`}
          />
        </div>

        <div class="lg:col-span-9 space-y-5">
          {siteConfig.projects.map((project, index) => (
            <div class="group project-card rounded-xl p-5 sm:p-6 md:p-8 transition-all duration-300 relative">

              {/* Arrow link — top right */}
              {project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="absolute top-5 right-5 sm:top-6 sm:right-6 w-8 h-8 flex items-center justify-center rounded-full transition-all duration-300 arrow-btn"
                  style={`color: ${siteConfig.accentColor}; --arrow-bg: ${siteConfig.accentColor}15; --arrow-bg-hover: ${siteConfig.accentColor}33`}
                  aria-label={`Open ${project.name}`}
                >
                  <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
                  </svg>
                </a>
              )}

              <div class="space-y-3">
                <div class="flex items-center gap-3">
                  {(project.icon || project.iconSrc) && (
                    <div
                      class="shrink-0 w-9 h-9 rounded-lg flex items-center justify-center"
                      style={`background-color: ${siteConfig.accentColor}12`}
                    >
                      <img
                        src={project.iconSrc ?? `https://cdn.simpleicons.org/${project.icon}`}
                        alt={project.name}
                        width="20"
                        height="20"
                        loading="lazy"
                        class="w-5 h-5"
                      />
                    </div>
                  )}
                  <div>
                    <span class="text-xs font-mono" style={`color: ${siteConfig.accentColor}80`}>
                      {String(index + 1).padStart(2, "0")}
                    </span>
                    <h3 class="text-base sm:text-lg font-semibold mt-0.5" style="color: var(--text-primary)">
                      {project.name}
                    </h3>
                  </div>
                </div>

                <p class={`text-sm sm:text-base leading-relaxed sm:text-justify ${project.link ? "pr-10" : ""}`} style="color: var(--text-secondary)">
                  {project.description}
                </p>

                {project.skills.length > 0 && (
                  <div class="flex flex-wrap gap-2 pt-1">
                    {project.skills.map((skill) => {
                      const src = getIconSrc(skill);
                      return (
                        <span
                          class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-medium rounded-md"
                          style={`color: ${siteConfig.accentColor}; background-color: ${siteConfig.accentColor}20; border: 1px solid ${siteConfig.accentColor}40`}
                        >
                          {src && (
                            <img src={src} alt={skill} width="12" height="12" loading="lazy" class="w-3 h-3 shrink-0" />
                          )}
                          {skill}
                        </span>
                      );
                    })}
                  </div>
                )}

                {project.credits && (
                  <div class="pt-3 mt-1 flex items-center gap-3" style="border-top: 1px solid var(--border)">
                    <span class="text-xs shrink-0" style="color: var(--text-muted)">Frontend by</span>
                    <a
                      href={project.credits.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="credits-link inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-medium transition-all duration-200"
                      style={`color: var(--text-secondary); background-color: ${siteConfig.accentColor}10; border: 1px solid ${siteConfig.accentColor}25`}
                    >
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19c-4.3 1.4-4.3-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 00-1.3-3.2 4.2 4.2 0 00-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 00-6.2 0C6.5 5.8 5.4 6.1 5.4 6.1a4.2 4.2 0 00-.1 3.2A4.6 4.6 0 004 12.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21" />
                      </svg>
                      {project.credits.label}
                    </a>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .project-card {
    background-color: var(--bg-surface);
    border: 1px solid var(--border);
  }
  .project-card:hover {
    border-color: var(--border-hover);
    background-color: var(--bg-surface-hover);
    transform: translateY(-2px);
  }
  .arrow-btn {
    background-color: var(--arrow-bg);
  }
  .group:hover .arrow-btn {
    background-color: var(--arrow-bg-hover);
  }
</style>
